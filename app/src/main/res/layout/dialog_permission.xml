<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="24dp">

    <!-- 标题 -->
    <TextView
        android:id="@+id/perm_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="权限不足"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 消息内容 -->
    <TextView
        android:id="@+id/perm_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:id="@+id/perm_btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/perm_btn_neutral"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:text="取消"
            android:textColor="@color/bg"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/perm_btn_root"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:layout_marginLeft="8dp"
            android:text="Root激活"
            android:textColor="@color/bg"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/perm_btn_shizuku"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:layout_marginLeft="8dp"
            android:text="Shizuku激活"
            android:textColor="@color/bg"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/perm_btn_positive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:layout_marginLeft="8dp"
            android:text="申请Shizuku权限"
            android:textColor="@color/bg"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>