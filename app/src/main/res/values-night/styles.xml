<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/bg</item>
        <item name="android:colorPrimaryDark">#354190</item>
        <item name="android:colorAccent">@color/bg</item>
        <item name="android:windowBackground">@color/screen_bg</item>
    </style>

    <style name="ToolbarOverlay">
        <item name="android:actionMenuTextAppearance">@style/ToolbarMenuTextStyle</item>
    </style>

    <style name="ToolbarMenuTextStyle">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#DEE0E0E0</item>
    </style>
</resources>